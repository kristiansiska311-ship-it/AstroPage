APP_ENV=development
APP_DEBUG=true
PORT=8000

# HMAC signing key for the legacy signed-endpoint helper.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# Async driver URL. Matches the docker-compose `db` service defaults.
DATABASE_URL=postgresql+asyncpg://astropage:astropage@localhost:5432/astropage

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
JWT_TTL_MINUTES=720

# Fernet key used to encrypt EduPage session cookies at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If left blank, a key is derived from SECRET_KEY (fine for dev, set explicitly in prod).
FERNET_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# The React frontend origin allowed to call this API.
FRONTEND_ORIGIN=http://localhost:5173

# ── AI assistant ──────────────────────────────────────────────────────────────
# Required for the homework assistant and agents/.
ANTHROPIC_API_KEY=
